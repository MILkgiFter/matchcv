{
  "name": "matchcv",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "start:lan": "expo start --lan",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-production.ps1",
    "release:setup": "powershell -ExecutionPolicy Bypass -File scripts/release-setup.ps1",
    "setup:bat": "scripts\\setup-production.bat",
    "generate:icons": "node scripts/generate-icons.js",
    "validate:prod": "node scripts/validate-production.js --profile production",
    "validate:preview": "node scripts/validate-production.js --profile preview",
    "release:preview": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1 -Target preview",
    "release:prod": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1 -Target production",
    "prebuild:android": "npm run validate:prod",
    "prebuild:ios": "npm run validate:prod",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "build:preview": "eas build --platform android --profile preview",
    "update": "eas update --branch production",
    "backend:dev": "npm run dev --prefix backend",
    "backend:install": "npm install --prefix backend",
    "backend:build": "npm run build --prefix backend",
    "backend:start": "npm start --prefix backend",
    "docker:up": "docker compose -f backend/docker-compose.yml up --build"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.0",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-localization": "~16.0.1",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.27.5",
    "i18next": "^26.3.1",
    "llama.rn": "^0.6.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^17.0.8",
    "react-native": "0.76.5",
    "react-native-purchases": "^10.4.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.0"
  },
  "private": true
}
